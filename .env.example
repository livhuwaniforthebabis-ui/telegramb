# Telegram Bot Token
TELEGRAM_TOKEN=YOUR_BOT_TOKEN_HERE

# Channel ID (VIP channel)
CHANNEL_ID=-1001234567890

# Your Telegram user ID (admin commands)
ADMIN_ID=123456789

# Minimum confidence to send signals
MIN_CONFIDENCE=80

# Extreme confidence (optional high threshold)
EXTREME_CONFIDENCE=92

# Risk-Reward ratios
TP1_RR=2
TP2_RR=3

# Scheduler intervals
SCAN_INTERVAL=5          # minutes between market scans
MONITOR_INTERVAL=60      # seconds between trade monitoring (if added)
